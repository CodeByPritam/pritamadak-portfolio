---
import '../assets/css/globals.css';
import '../assets/css/style.css';
import '../assets/css/app.css';

interface Props { title: string; }
const { title } = Astro.props;
const p = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1, user-scalable=no">
    <title> {title} </title>
    <link rel="icon" href="/favicon.ico" >
</head>
<body>

    <!--- Desktop: Begin --->
    <div class="desktop">
        <div class="terminal" id="term">

            <!--- Title Bar --->
            <div class="title-bar">
                <div class="dots">
                    <div class="dot dot-r"></div>
                    <div class="dot dot-y"></div>
                    <div class="dot dot-g"></div>
                </div>
                <div class="titlebar-text"><b>dev@pritamadak</b> — <b>~/portfolio</b> — zsh</div>
                <div class="version">v1.0</div>
            </div> 

            <!--- Tab Bar --->
            <div class="tab-bar">
                <button class="tab active" onclick="tabSwitch('about')"> ~/about</button>
                <button class="tab" onclick="tabSwitch('projects')"> ~/projects</button>
                <button class="tab" onclick="tabSwitch('skills')">⚡skills</button>
                <button class="tab" onclick="tabSwitch('education')"> ~/education</button>
                <button class="tab" onclick="tabSwitch('experience')"> ~/experience</button>
                <button class="tab" onclick="tabSwitch('contact')"> ~/contact</button>
            </div>

            <!--- Terminal Body --->
            <div id="terminal-body"> <slot/> </div>

            <!--- Status Bar --->
            <div class="status-bar">
                <div class="sb-item" id="year">© 2026</div>
                <div class="sb-item sb-sep">|</div>
                <div class="sb-item git-branch">(master)</div>
                <div class="sb-item sb-sep">|</div>
                <div class="sb-item">[] portfolio</div>
                <div style="flex:1"></div>
                <div class="sb-item">Creator: <a href="https://instagram.com/pritamadakdev" target="_blank">Pritam Adak</a></div>
                <div class="sb-item sb-sep">|</div>
                <div class="sb-item" id="clock">--:--:-- -- ---</div>
            </div>

        </div>
    </div>
    <!--- Desktop: End --->

    <script src="../assets/javascript/services.js"></script>
</body>
</html>