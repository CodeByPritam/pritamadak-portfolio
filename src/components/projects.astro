---
const { data } = Astro.props;
---

<section class="section" id="projects">

    <!--- System: Prompt Block --->
    <div class="prompt-block">
        <div class="prompt-line">
            <span class="p-user">{data.app.system.username}</span>
            <span class="p-at">@</span>
            <span class="p-host">{data.app.system.host}</span>
            <span class="p-colon">:</span>
            <span class="p-path">{data.app.system.path}</span>
            <span class="p-git">({data.app.system.gitBranch})</span>
            <span class="p-sym">❯</span>
            <span class="arg">{data.projects.prompt}</span>
        </div>
    </div>

    <!--- Output: Commit History --->
    <div class="output">
        <div class="output-line">
            <span class="comment">{data.projects.comment}</span>
        </div>
    </div>

    {[...data.projects.items].sort((a, b) => b._idx - a._idx).map((elm) => (
        <div class="project-card">
            <div class="proj-duration">
                <div class="start">{elm.duration.start}</div>
                <p class="dash">-</p>
                <div class="end">{elm.duration.end}</div>
            </div>
            <a class="proj-name" href={elm.githubLink} target="_blank">
                {elm.name} <i class="fa-solid fa-link"></i>
            </a>
            <div class="proj-desc">{elm.desc}</div>
            <div class="proj-techstack">
                {elm.techStack.map((ts) => (
                    <div class="tsname">{ts}</div>
                ))}
            </div>
        </div>
    ))}
    
</section>