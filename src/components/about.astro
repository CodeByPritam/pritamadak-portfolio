            <div class="nf-row">
                <span class="nf-k">OS</span>
                <span class="nf-sep">:</span>
                <span class="nf-v">Arch Linux x86</span>
            </div>
            <div class="nf-row">
                <span class="nf-k">Host</span>
                <span class="nf-sep">:</span>
                <span class="nf-v">Lenovo Ideapad Gaming 3</span>
            </div>
            <div class="nf-row">
                <span class="nf-k">Shell</span>
                <span class="nf-sep">:</span>
                <span class="nf-v">zsh + oh-my-zsh</span>
            </div>
            <div class="nf-row">
                <span class="nf-k">Terminal</span>
                <span class="nf-sep">:</span>
