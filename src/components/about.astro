                    <a href="https://github.com/catppuccin/catppuccin" target="_blank">Catppuccin Mocha</a>
                </span>
            </div>
            <div class="nf-row">
                <span class="nf-k">Font</span>
                <span class="nf-sep">:</span>
                <span class="nf-v">Cascadia Code</span>
            </div>
            <div class="color-palette">
                <div class="swatch" style="background:var(--red)"></div>
                <div class="swatch" style="background:var(--maroon)"></div>
                <div class="swatch" style="background:var(--peach)"></div>
                <div class="swatch" style="background:var(--yellow)"></div>
                <div class="swatch" style="background:var(--green)"></div>
                <div class="swatch" style="background:var(--teal)"></div>
                <div class="swatch" style="background:var(--sky)"></div>
