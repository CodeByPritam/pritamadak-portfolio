<section class="section active" id="about">
    
    <!--- System: Prompt Block --->
    <div class="prompt-block">
        <div class="prompt-line">
            <span class="p-user">pritamadak</span>
            <span class="p-at">@</span>
            <span class="p-host">arch</span>
            <span class="p-colon">:</span>
            <span class="p-path">~/portfolio</span>
            <span class="p-git">(master)</span>
            <span class="p-sym">❯</span>
            <span class="arg">show -me</span>
        </div>
    </div>

    <!--- ASCII style --->
